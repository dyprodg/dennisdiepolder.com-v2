---
/**
 * Main Layout Component
 * Swiss Design System Integration
 */
import SwissGridOverlay from '../components/SwissGridOverlay.astro';
import SmoothScroll from '../components/SmoothScroll.astro';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Dennis Diepolder - Frontend Engineer & Automation Specialist. Building digital experiences with Swiss precision."
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO Meta Tags -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />

    <!-- Fonts: Inter Variable (all weights) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&display=swap" rel="stylesheet" />

    <title>{title}</title>
  </head>
  <body>
    <!-- Skip to content link (accessibility) -->
    <a href="#main-content" class="skip-to-content">
      Skip to content
    </a>

    <!-- Main content -->
    <slot />

    <!-- Swiss Grid Overlay (toggle with Ctrl+G) -->
    <SwissGridOverlay />

    <!-- Lenis Smooth Scrolling -->
    <SmoothScroll />
  </body>
</html>

<style is:global>
  /* ========================================
     SWISS DESIGN SYSTEM - GLOBAL STYLES
     Import order matters!
     ======================================== */

  /* 1. Design Tokens (CSS Variables) */
  @import '../styles/base/variables.css';

  /* 2. CSS Reset */
  @import '../styles/base/reset.css';

  /* 3. Typography */
  @import '../styles/base/typography.css';

  /* 4. Layout System */
  @import '../styles/layout/grid.css';
</style>
