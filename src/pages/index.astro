---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Dennis Diepolder - Frontend & Automation">

  <main>
    <!-- Hero Section -->
    <section class="hero">
      <div class="container">
        <div class="hero-content">
          <div class="profile-image-container">
            <img
              src="/profile.jpeg"
              alt="Dennis Diepolder"
              class="profile-image"
            />
          </div>
          <div class="hero-text">
            <h1 class="name">Dennis Diepolder</h1>
            <p class="tagline">Performance Manager & Tech Enthusiast</p>
            <p class="description">
              Driving business success through performance optimization and strategic client communication.
              As a Performance Manager for a Swiss hotline, I focus on achieving company targets while
              leveraging technology and AI to maximize efficiency and results.
            </p>
            <div class="cta-buttons">
              <a href="#contact" class="btn btn-primary">Get in Touch</a>
              <a href="#about" class="btn btn-secondary">Learn More</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- About Section -->
    <section id="about" class="about">
      <div class="container">
        <h2 class="section-title">What I Do</h2>
        <div class="cards-grid">
          <div class="card" data-scroll-animate>
            <div class="card-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M3 3v18h18"/>
                <path d="M18 17V9"/>
                <path d="M13 17V5"/>
                <path d="M8 17v-3"/>
              </svg>
            </div>
            <h3>Performance Management</h3>
            <p>Driving business targets and KPI achievement for a Swiss hotline operation with strategic planning and data-driven decisions.</p>
          </div>
          <div class="card" data-scroll-animate>
            <div class="card-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
              </svg>
            </div>
            <h3>Client Relations</h3>
            <p>Managing stakeholder communication and ensuring client satisfaction through transparent reporting and proactive problem-solving.</p>
          </div>
          <div class="card" data-scroll-animate>
            <div class="card-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="2" y="3" width="20" height="14" rx="2"/>
                <path d="M8 21h8"/>
                <path d="M12 17v4"/>
                <path d="M7 8h10"/>
                <path d="M7 12h6"/>
              </svg>
            </div>
            <h3>Tech & Automation</h3>
            <p>Leveraging AI and modern technology to optimize workflows, enhance productivity, and achieve operational excellence.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Contact Section -->
    <section id="contact" class="contact">
      <div class="container">
        <h2 class="section-title">Let's Connect</h2>
        <p class="contact-description" data-scroll-animate>
          Interested in collaboration or just want to chat about tech? Let's get in touch.
        </p>
        <div class="contact-buttons" data-scroll-animate>
          <a href="mailto:info@dennisdiepolder.com" class="contact-btn email-btn">
            <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
            <span>Email Me</span>
          </a>
          <a href="https://www.linkedin.com/in/dennis-diepolder-2a5a98276/" target="_blank" rel="noopener noreferrer" class="contact-btn linkedin-btn">
            <svg class="icon" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            <span>LinkedIn</span>
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>

<script>
  // Intersection Observer for scroll-based animations
  const observerOptions = {
    threshold: 0.1,
    rootMargin: '0px 0px -100px 0px'
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('animate-in');
      }
    });
  }, observerOptions);

  // Observe all elements with data-scroll-animate
  document.addEventListener('DOMContentLoaded', () => {
    const animateElements = document.querySelectorAll('[data-scroll-animate]');
    animateElements.forEach(el => observer.observe(el));

    // Add parallax effect to hero section
    const hero = document.querySelector('.hero');
    if (hero) {
      window.addEventListener('scroll', () => {
        const scrolled = window.pageYOffset;
        const heroContent = document.querySelector('.hero-content') as HTMLElement;
        if (heroContent && scrolled < window.innerHeight) {
          heroContent.style.transform = `translateY(${scrolled * 0.3}px)`;
          heroContent.style.opacity = `${1 - scrolled / 700}`;
        }
      });
    }

    // Smooth reveal for section titles
    const sectionTitles = document.querySelectorAll('.section-title');
    const titleObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('title-reveal');
        }
      });
    }, { threshold: 0.5 });

    sectionTitles.forEach(title => titleObserver.observe(title));
  });
</script>

<style>
  /* ========================================
     SWISS DESIGN - PAGE STYLES
     Using design system tokens
     ======================================== */

  main {
    background: linear-gradient(135deg, var(--color-white) 0%, var(--color-grey-100) 100%);
    min-height: 100vh;
  }

  /* Main content ID for skip-to-content */
  main {
    scroll-margin-top: var(--space-8);
  }

  /* ========================================
     HERO SECTION
     ======================================== */

  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: var(--space-8) 0;
  }

  .hero-content {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: var(--space-8);
    align-items: center;
    animation: fadeInUp var(--duration-slow) var(--ease-swift-out);
  }

  .profile-image-container {
    position: relative;
    animation: fadeIn var(--duration-slow) var(--ease-decelerate) 0.2s both;
  }

  .profile-image {
    width: 100%;
    max-width: 350px;
    height: auto;
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: var(--border-radius-small);
    filter: grayscale(100%);
    transition: all var(--transition-swift);
    border: var(--border-width-thin) solid var(--color-border);
  }

  .profile-image:hover {
    filter: grayscale(0%);
    transform: translateY(-5px);
    box-shadow: var(--shadow-xlarge);
  }

  .hero-text {
    animation: fadeInRight var(--duration-slow) var(--ease-swift-out) 0.3s both;
  }

  .name {
    font-size: var(--font-size-h1);
    font-weight: var(--font-weight-bold);
    letter-spacing: var(--letter-spacing-tight);
    margin-bottom: var(--space-2);
    color: var(--color-black);
    line-height: var(--line-height-tight);
  }

  .tagline {
    font-size: var(--font-size-24);
    color: var(--color-grey-600);
    margin-bottom: var(--space-3);
    font-weight: var(--font-weight-regular);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wide);
    font-size: var(--font-size-12);
  }

  .description {
    font-size: var(--font-size-18);
    line-height: var(--line-height-relaxed);
    color: var(--color-grey-800);
    margin-bottom: var(--space-4);
    max-width: 600px;
  }

  .cta-buttons {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  /* Swiss Button Styles */
  .btn {
    padding: var(--space-2) var(--space-4);
    font-size: var(--font-size-16);
    text-decoration: none;
    border-radius: var(--border-radius-small);
    transition: all var(--transition-default);
    cursor: pointer;
    border: var(--border-width-medium) solid transparent;
    display: inline-block;
    font-weight: var(--font-weight-semibold);
    position: relative;
    overflow: hidden;
  }

  .btn-primary {
    background: var(--color-black);
    color: var(--color-white);
    border-color: var(--color-black);
  }

  .btn-primary:hover {
    background: var(--color-accent);
    border-color: var(--color-accent);
    transform: translateY(-2px);
    box-shadow: var(--shadow-medium);
  }

  .btn-secondary {
    background: transparent;
    color: var(--color-black);
    border-color: var(--color-black);
  }

  .btn-secondary:hover {
    background: var(--color-black);
    color: var(--color-white);
    transform: translateY(-2px);
  }

  /* ========================================
     ABOUT SECTION
     ======================================== */

  .about {
    padding: var(--space-section) 0;
    background: var(--color-white);
  }

  .section-title {
    font-size: var(--font-size-h2);
    font-weight: var(--font-weight-bold);
    text-align: center;
    margin-bottom: var(--space-component);
    color: var(--color-black);
    letter-spacing: var(--letter-spacing-tight);
    opacity: 0;
    transform: translateY(20px);
    transition: all var(--transition-swift);
  }

  .section-title.title-reveal {
    opacity: 1;
    transform: translateY(0);
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--space-4);
  }

  /* Swiss Card Design */
  .card {
    padding: var(--space-5);
    background: var(--color-grey-100);
    border: var(--border-width-thin) solid var(--color-border);
    border-radius: var(--border-radius-small);
    transition: all var(--transition-swift);
    opacity: 0;
    transform: translateY(50px);
    position: relative;
  }

  /* Red accent line (Swiss railway style) */
  .card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 0;
    height: var(--border-width-thick);
    background: var(--color-accent);
    transition: width var(--transition-default);
  }

  .card:hover::before {
    width: 100%;
  }

  .card.animate-in {
    animation: slideInUp var(--duration-slow) var(--ease-swift-out) forwards;
  }

  .card:nth-child(1).animate-in {
    animation-delay: 0.1s;
  }

  .card:nth-child(2).animate-in {
    animation-delay: 0.3s;
  }

  .card:nth-child(3).animate-in {
    animation-delay: 0.5s;
  }

  .card:hover {
    transform: translateY(-8px);
    box-shadow: var(--shadow-large);
    border-color: var(--color-grey-300);
  }

  .card-icon {
    width: 64px;
    height: 64px;
    margin-bottom: var(--space-3);
    color: var(--color-black);
    transition: all var(--transition-default);
  }

  .card-icon svg {
    width: 100%;
    height: 100%;
    stroke-width: 1.5;
  }

  .card:hover .card-icon {
    color: var(--color-accent);
    transform: scale(1.1);
  }

  .card h3 {
    font-size: var(--font-size-24);
    font-weight: var(--font-weight-semibold);
    margin-bottom: var(--space-2);
    color: var(--color-black);
  }

  .card p {
    color: var(--color-grey-800);
    line-height: var(--line-height-relaxed);
    font-size: var(--font-size-16);
  }

  /* ========================================
     CONTACT SECTION
     ======================================== */

  .contact {
    padding: var(--space-section) 0;
    background: var(--color-grey-100);
  }

  .contact-description {
    text-align: center;
    font-size: var(--font-size-20);
    color: var(--color-grey-800);
    margin-bottom: var(--space-6);
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
    opacity: 0;
    transform: translateY(30px);
    transition: all var(--transition-slow);
  }

  .contact-description.animate-in {
    opacity: 1;
    transform: translateY(0);
  }

  .contact-buttons {
    display: flex;
    gap: var(--space-3);
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
    opacity: 0;
    transform: translateY(30px);
    transition: all var(--transition-slow) 0.2s;
  }

  .contact-buttons.animate-in {
    opacity: 1;
    transform: translateY(0);
  }

  .contact-btn {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-5);
    font-size: var(--font-size-18);
    font-weight: var(--font-weight-semibold);
    text-decoration: none;
    border-radius: var(--border-radius-small);
    transition: all var(--transition-default);
    border: var(--border-width-medium) solid transparent;
  }

  .contact-btn .icon {
    width: 24px;
    height: 24px;
    transition: transform var(--transition-default);
  }

  .email-btn {
    background: var(--color-black);
    color: var(--color-white);
    border-color: var(--color-black);
  }

  .email-btn:hover {
    background: var(--color-accent);
    border-color: var(--color-accent);
    transform: translateY(-3px);
    box-shadow: var(--shadow-large);
  }

  .email-btn:hover .icon {
    transform: translateY(-2px);
  }

  .linkedin-btn {
    background: #0077b5;
    color: var(--color-white);
    border-color: #0077b5;
  }

  .linkedin-btn:hover {
    background: #005582;
    transform: translateY(-3px);
    box-shadow: 0 10px 25px rgba(0, 119, 181, 0.3);
  }

  .linkedin-btn:hover .icon {
    transform: scale(1.1);
  }

  /* ========================================
     KEYFRAME ANIMATIONS
     ======================================== */

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @keyframes fadeInRight {
    from {
      opacity: 0;
      transform: translateX(-30px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  @keyframes slideInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ========================================
     RESPONSIVE DESIGN
     ======================================== */

  @media (max-width: 968px) {
    .hero-content {
      grid-template-columns: 1fr;
      text-align: center;
      gap: var(--space-6);
    }

    .profile-image {
      max-width: 250px;
      margin: 0 auto;
    }

    .description {
      margin-left: auto;
      margin-right: auto;
    }

    .cta-buttons {
      justify-content: center;
    }
  }

  @media (max-width: 640px) {
    .cards-grid {
      grid-template-columns: 1fr;
    }

    .btn {
      width: 100%;
      text-align: center;
    }

    .contact-buttons {
      flex-direction: column;
      width: 100%;
    }

    .contact-btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>
