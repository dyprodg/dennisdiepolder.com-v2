---
/**
 * Parallax Component
 * GSAP-powered smooth parallax scrolling
 */
interface Props {
  speed?: number;
  direction?: 'up' | 'down';
  class?: string;
}

const {
  speed = 0.5,
  direction = 'up',
  class: className = '',
} = Astro.props;

const uniqueId = `parallax-${Math.random().toString(36).substr(2, 9)}`;
const multiplier = direction === 'down' ? -1 : 1;
---

<div
  id={uniqueId}
  class:list={['parallax-wrapper', className]}
  data-speed={speed}
  data-direction={direction}
>
  <div class="parallax-content">
    <slot />
  </div>
</div>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initParallax() {
    const elements = document.querySelectorAll('.parallax-wrapper');

    elements.forEach((wrapper) => {
      const content = wrapper.querySelector('.parallax-content');
      if (!content) return;

      const speed = parseFloat(wrapper.getAttribute('data-speed') || '0.5');
      const direction = wrapper.getAttribute('data-direction') || 'up';
      const multiplier = direction === 'down' ? -1 : 1;

      gsap.to(content, {
        y: () => `${multiplier * speed * 100}%`,
        ease: 'none',
        scrollTrigger: {
          trigger: wrapper,
          start: 'top bottom',
          end: 'bottom top',
          scrub: true,
        },
      });
    });
  }

  // Initialize on DOMContentLoaded
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initParallax);
  } else {
    initParallax();
  }

  // Re-initialize on navigation
  document.addEventListener('astro:page-load', initParallax);
</script>

<style>
  .parallax-wrapper {
    overflow: hidden;
    will-change: transform;
  }

  .parallax-content {
    will-change: transform;
  }

  /* Accessibility: Reduce motion */
  @media (prefers-reduced-motion: reduce) {
    .parallax-content {
      transform: none !important;
    }
  }
</style>
