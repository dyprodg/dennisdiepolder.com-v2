---
/**
 * Swiss Grid Overlay Component
 * Toggle-able grid visualizer (Ctrl+G or Cmd+G)
 * Shows 12-column grid + 8px baseline grid
 */
---

<div class="swiss-grid-overlay" id="swissGridOverlay" aria-hidden="true">
  <div class="baseline-grid"></div>
  <div class="grid-container">
    <div class="grid-column"></div>
    <div class="grid-column"></div>
    <div class="grid-column"></div>
    <div class="grid-column"></div>
    <div class="grid-column"></div>
    <div class="grid-column"></div>
    <div class="grid-column"></div>
    <div class="grid-column"></div>
    <div class="grid-column"></div>
    <div class="grid-column"></div>
    <div class="grid-column"></div>
    <div class="grid-column"></div>
  </div>
</div>

<div class="grid-toggle-indicator" id="gridToggleIndicator">
  Grid: ON (Ctrl+G to toggle)
</div>

<script>
  // Grid overlay toggle logic
  const overlay = document.getElementById('swissGridOverlay');
  const indicator = document.getElementById('gridToggleIndicator');
  let isGridVisible = false;
  let indicatorTimeout: number;

  function toggleGrid() {
    isGridVisible = !isGridVisible;

    if (isGridVisible) {
      overlay?.classList.add('visible');
      showIndicator('ON');
    } else {
      overlay?.classList.remove('visible');
      showIndicator('OFF');
    }

    // Save preference to localStorage
    localStorage.setItem('swiss-grid-visible', String(isGridVisible));
  }

  function showIndicator(state: string) {
    if (!indicator) return;

    indicator.textContent = `Grid: ${state} (Ctrl+G to toggle)`;
    indicator.classList.add('visible');

    // Clear existing timeout
    if (indicatorTimeout) {
      clearTimeout(indicatorTimeout);
    }

    // Hide indicator after 2 seconds
    indicatorTimeout = setTimeout(() => {
      indicator.classList.remove('visible');
    }, 2000);
  }

  // Keyboard shortcut: Ctrl+G (or Cmd+G on Mac)
  document.addEventListener('keydown', (e) => {
    if ((e.ctrlKey || e.metaKey) && e.key === 'g') {
      e.preventDefault();
      toggleGrid();
    }
  });

  // Restore grid state from localStorage on page load
  document.addEventListener('DOMContentLoaded', () => {
    const savedState = localStorage.getItem('swiss-grid-visible');
    if (savedState === 'true') {
      isGridVisible = true;
      overlay?.classList.add('visible');
    }
  });

  // Expose toggle function globally (for debugging/testing)
  (window as any).toggleSwissGrid = toggleGrid;
</script>

<style>
  /* Component-specific styles (base styles in grid.css) */
  .swiss-grid-overlay {
    animation: fadeIn 0.3s ease-out;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  /* Responsive grid columns */
  @media (max-width: 1023px) {
    .swiss-grid-overlay .grid-container {
      grid-template-columns: repeat(6, 1fr);
      padding: 0 var(--grid-gutter-tablet);
    }

    .swiss-grid-overlay .grid-column:nth-child(n+7) {
      display: none;
    }
  }

  @media (max-width: 767px) {
    .swiss-grid-overlay .grid-container {
      grid-template-columns: repeat(2, 1fr);
      padding: 0 var(--grid-gutter-mobile);
    }

    .swiss-grid-overlay .grid-column:nth-child(n+3) {
      display: none;
    }
  }

  /* Make indicator more visible on mobile */
  @media (max-width: 767px) {
    .grid-toggle-indicator {
      font-size: var(--font-size-14);
      padding: var(--space-2) var(--space-3);
    }
  }
</style>
