---
/**
 * Kinetic Typography Component
 * DRAMATIC text animation that's impossible to miss
 */
interface Props {
  text: string;
  tag?: 'h1' | 'h2' | 'h3' | 'p' | 'span';
  class?: string;
  delay?: number;
  stagger?: number;
}

const {
  text,
  tag = 'h2',
  class: className = '',
  delay = 0.3,           // Longer initial delay
  stagger = 0.08,        // Slower stagger
} = Astro.props;

const Tag = tag;
const uniqueId = `kinetic-${Math.random().toString(36).substr(2, 9)}`;
---

<Tag
  id={uniqueId}
  class:list={['kinetic-text', className]}
  data-text={text}
  data-delay={delay}
  data-stagger={stagger}
>
  {text}
</Tag>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initKineticText() {
    const elements = document.querySelectorAll('.kinetic-text');

    elements.forEach((el) => {
      const text = el.getAttribute('data-text') || el.textContent || '';
      const delay = parseFloat(el.getAttribute('data-delay') || '0.3');
      const stagger = parseFloat(el.getAttribute('data-stagger') || '0.08');

      // Split text into characters with individual spans
      el.innerHTML = text
        .split('')
        .map((char) => {
          if (char === ' ') return '<span class="char">&nbsp;</span>';
          return `<span class="char">${char}</span>`;
        })
        .join('');

      const chars = el.querySelectorAll('.char');

      // DRAMATIC kinetic animation - impossible to miss!
      gsap.from(chars, {
        opacity: 0,
        y: 100,                    // Come from much further down
        rotationX: -120,           // More rotation
        rotationZ: -15,            // Add z-axis rotation for more drama
        scale: 0.5,                // Start smaller
        transformOrigin: '50% 50%',
        duration: 1.2,             // MUCH slower
        delay,
        stagger: {
          amount: stagger * (chars.length - 1), // Slower overall stagger
          from: 'start',
        },
        ease: 'back.out(1.4)',     // Bounce effect
        scrollTrigger: {
          trigger: el,
          start: 'top 75%',        // Trigger earlier
          toggleActions: 'play none none none',
          markers: false,          // Set to true for debugging
        },
      });
    });

    console.log('🎨 Kinetic typography initialized');
  }

  // Initialize with a small delay to ensure DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      setTimeout(initKineticText, 100);
    });
  } else {
    setTimeout(initKineticText, 100);
  }

  // Re-initialize on navigation
  document.addEventListener('astro:page-load', () => {
    setTimeout(initKineticText, 100);
  });
</script>

<style>
  .kinetic-text {
    display: inline-block;
    perspective: 1000px;
  }

  .kinetic-text :global(.char) {
    display: inline-block;
    transform-style: preserve-3d;
    will-change: transform, opacity;
  }

  /* Accessibility: Reduce motion */
  @media (prefers-reduced-motion: reduce) {
    .kinetic-text :global(.char) {
      animation: none !important;
      transform: none !important;
    }
  }
</style>
